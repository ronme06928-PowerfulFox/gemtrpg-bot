#let hr() = {
  line(length: 100%, stroke: 0.8pt + luma(75%))
}

// 汎用ボックス（改行に \ を使わない：stackで組む）
#let box(body, title: none, kind: "rule") = {
  let (stroke_col, fill_col, label) = (
    if kind == "warn" { (luma(55%), luma(93%), "注意") }
    else if kind == "def" { (luma(60%), luma(96%), "定義") }
    else if kind == "ex" { (luma(60%), luma(96%), "例") }
    else { (luma(55%), luma(97%), "ルール") }
  )

  let head = if title != none { title } else { label }

  block(
    inset: (x: 10pt, y: 8pt),
    radius: 6pt,
    stroke: 0.9pt + stroke_col,
    fill: fill_col,
  )[
    #stack(
      spacing: 4pt,
      [*#head*],
      body,
    )
  ]
}

#let rule_box(body, title: none) = box(body, title: title, kind: "rule")
#let warn_box(body, title: none) = box(body, title: title, kind: "warn")
#let def_box(body, title: none) = box(body, title: title, kind: "def")
#let ex_box(body, title: none) = box(body, title: title, kind: "ex")

// 注記：注意ボックスへ寄せる（既存コード互換）
#let note(body) = warn_box(body, title: "注記")

// 手順ボックス（改行に \ を使わない）
#let steps(body, title: "手順") = block(
  inset: (x: 10pt, y: 8pt),
  radius: 6pt,
  stroke: 0.9pt + luma(55%),
  fill: luma(97%),
)[
  #stack(
    spacing: 4pt,
    [*#title*],
    body,
  )
]

// 用語表（2列・ボックス）
// tableの行生成で `it` を作らず、gridで順番に流し込む（for はここで確実に動く）
#let terms_table(items) = {
  // 2列×N行ぶんのセルを先に作る
  let cells = ()
  for pair in items {
    cells.push([*#pair.at(0)*])
    cells.push([#pair.at(1)])
  }

  block(
    inset: (x: 10pt, y: 8pt),
    radius: 6pt,
    stroke: 0.8pt + luma(70%),
    fill: luma(98%),
  )[
    #table(
      columns: (33%, 67%),
      inset: (x: 6pt, y: 5pt),

      // 内側の格子罫線
      stroke: 0.6pt + luma(82%),

      // ヘッダ
      table.header(
        table.cell(fill: luma(94%))[*用語*],
        table.cell(fill: luma(94%))[*説明*],
      ),

      // 本文
      ..cells
    )
  ]
}

// ステータス一覧（見出し1行＋中身1行）
#let stat_row(title, items, cols) = {
  table(
    columns: cols,
    inset: (x: 6pt, y: 5pt),
    stroke: 0.6pt + luma(82%),

    table.cell(colspan: items.len())[*#title*],
    ..for s in items { [#s] }
  )
}

