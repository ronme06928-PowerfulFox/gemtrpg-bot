#set heading(
  numbering: (..nums) => {
    let pos = nums.pos()
    if pos.len() <= 3 { numbering("1.1.1", ..pos) }
  },
  outlined: true,
)
#show heading.where(level: 4): it => {
  v(0.6em)
  block[#text(weight: "bold", size: 12pt)[#it.body]]
  v(0.2em)
}
#show heading.where(level: 5): it => {
  v(0.4em)
  block[#text(weight: "bold", size: 11pt)[#it.body]]
  v(0.1em)
}

#set par(spacing: 0.6em)

#show link: it => {
  set text(fill: rgb(0, 102, 204))
  set underline(stroke: 0.6pt + rgb(0, 102, 204))
  it
}


